# Шаблон переменных для production-деплоя на VPS.
# Скопируйте в .env рядом с docker-compose.prod.yml и заполните:
#   cp .env.prod.example .env

# Публичный домен, направленный на VPS (без https://). Заведён в Nginx Proxy Manager.
PUBLIC_DOMAIN=videoner.sarsembai.dev

# Имя внешней docker-сети вашего Nginx Proxy Manager
NPM_NETWORK=proxy-network

# Телеграм
BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Общий секрет между server/web/bot. Сгенерировать: openssl rand -hex 32  (добавьте префикс dk_)
API_KEY=

# Необязательно
POSTGRES_PASSWORD=postgres
ADMIN_EMAIL=admin@localhost

# Telegram chat ID администратора — сюда сервер шлёт алерт, когда YouTube требует
# обновить cookies ("Sign in to confirm you're not a bot"). Узнать свой ID: @userinfobot
ADMIN_CHAT_ID=
