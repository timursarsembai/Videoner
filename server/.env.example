DATABASE_URL="postgresql://postgres:root@localhost:5432/downloader?schema=public"
ALLOWED_ORIGINS="*"
NODE_ENV="development"

# Необязательно: алерт в Telegram, когда YouTube требует обновить cookies.
BOT_TOKEN=
ADMIN_CHAT_ID=

# Необязательно: статический ISP-прокси для YouTube (обход блокировки по IP дата-центра).
YOUTUBE_PROXY_URL=
