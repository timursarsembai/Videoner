datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ApiKey {
  id          String     @id @default(uuid())
  key         String     @unique
  name        String // Descriptive name for the API key
  user        User       @relation(fields: [userId], references: [id])
  userId      String
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isBlocked   Boolean    @default(false)
  blockReason String?
  ipWhitelist String[] // Array of allowed IP addresses
  rateLimit   Int        @default(100) // Requests per minute
  maxDuration Int        @default(1800) // Maximum media duration in seconds (default 30 minutes)
  downloads   Download[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([key])
  @@index([userId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  apiKeys   ApiKey[]
  isAdmin   Boolean  @default(false)
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Download {
  id            String         @id @default(uuid())
  originalUrl   String
  status        DownloadStatus @default(PENDING)
  filename      String
  downloadUrl   String?
  downloader    Downloaders    @default(YOUTUBE)
  apiKey        ApiKey?        @relation(fields: [apiKeyId], references: [id])
  apiKeyId      String?
  botUser       BotUser?       @relation(fields: [botUserId], references: [id])
  botUserId     String?
  source        DownloadSource @default(API)
  videoTitle    String?
  videoDuration Int?
  fileSize      BigInt?
  isPaid        Boolean        @default(false)
  starsAmount   Int?
  errorCategory ErrorCategory?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([botUserId])
  @@index([status])
  @@index([downloader])
  @@index([createdAt])
}

model BotUser {
  id           String     @id @default(uuid())
  telegramId   BigInt     @unique
  username     String?
  firstName    String?
  languageCode String?
  isUnlimited  Boolean    @default(false)
  downloads    Download[]
  firstSeenAt  DateTime   @default(now())
  lastSeenAt   DateTime   @default(now())

  @@index([telegramId])
}

enum DownloadStatus {
  PENDING
  DOWNLOADING
  CONVERTING
  COMPLETED
  FAILED
  EXPIRED
}

enum Downloaders {
  YOUTUBE
  FACEBOOK
  INSTAGRAM
  TIKTOK
  TWITTER
  VIMEO
  VK
  RUTUBE
  OKRU
}

enum DownloadSource {
  BOT
  WEB
  API
}

enum ErrorCategory {
  LOGIN_REQUIRED
  UNSUPPORTED_PLATFORM
  FORMAT_UNAVAILABLE
  YOUTUBE_AUTH_REQUIRED
  TIMEOUT
  OTHER
}
