# Шаблон переменных для staging-контура (docker-compose.staging.yml).
# Проще всего — скопировать существующий .env и поменять только PUBLIC_DOMAIN:
#   cp .env .env.staging
#   sed -i 's/^PUBLIC_DOMAIN=.*/PUBLIC_DOMAIN=staging.videoner.download/' .env.staging
#
# Единственное смысловое отличие от прод-.env — домен. Все остальные секреты
# (API_KEY, BOT_TOKEN, TURNSTILE_SECRET, SESSION_SECRET и т.д.) staging
# переиспользует те же, что и прод — это ОДИН и тот же сайт/бот, просто на
# другом URL для безопасной проверки перед деплоем на реальный домен, а не
# отдельный продукт с собственными учётными данными.
#
# См. .env.prod.example для полного списка переменных и их описания —
# здесь дублируется только то, что отличается по смыслу.

PUBLIC_DOMAIN=staging.videoner.download
NPM_NETWORK=proxy-network
